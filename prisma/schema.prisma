generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  repositories  Repository[]
  exports       ExportArtifact[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Repository {
  id          String           @id @default(cuid())
  owner       String
  name        String
  fullName    String           @unique
  githubUrl   String
  githubId    String?
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans       Scan[]
  plans       DeploymentPlan[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Scan {
  id              String          @id @default(cuid())
  repositoryId    String
  repository      Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  status          String          @default("completed")
  framework       String?
  runtime         String?
  confidence      Float?
  summaryJson     Json
  findings        ScanFinding[]
  platformScores  PlatformScore[]
  createdAt       DateTime        @default(now())
}

model ScanFinding {
  id          String   @id @default(cuid())
  scanId      String
  scan        Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  filePath    String
  severity    String
  title       String
  detail      String
  lineNumber  Int?
  actionType  String?
  actionText  String?
  actionUrl   String?
  createdAt   DateTime @default(now())
}

model PlatformScore {
  id           String   @id @default(cuid())
  scanId       String
  scan         Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  platform     String
  score        Int
  verdict      String
  confidence   Float
  explanation  Json
  createdAt    DateTime @default(now())
}

model DeploymentPlan {
  id            String   @id @default(cuid())
  repositoryId  String
  repository    Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  platform      String
  title         String
  summary       String
  score         Int
  confidence    Float
  planJson      Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ExportArtifact {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  format      String
  repository  String
  platform    String
  content     String
  createdAt   DateTime @default(now())
}

